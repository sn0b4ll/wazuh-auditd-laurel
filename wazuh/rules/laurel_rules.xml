<!--
  LAUREL Audit Rules for Wazuh
  =============================
  Deploy to: /var/ossec/etc/rules/laurel_rules.xml  (on the Wazuh MANAGER)

  These rules consume JSON events produced by LAUREL (Linux Audit Usable
  Real-time Event Logging) and match on the audit keys defined in:
    /etc/audit/rules.d/audit.rules

  Rule ID range: 100100 - 100399
  All rules belong to group "laurel".

  LAUREL JSON field reference (dot-notation as seen by Wazuh):
    SYSCALL.key       - audit rule key (e.g. "exec", "priv_esc")
    SYSCALL.exe       - full path of the executed binary
    SYSCALL.comm      - short command name
    SYSCALL.SYSCALL   - human-readable syscall name
    SYSCALL.success   - "yes" or "no"
    SYSCALL.UID       - effective username
    SYSCALL.AUID      - audit (login) username or "unset"
    SYSCALL.uid       - numeric effective UID
    SYSCALL.auid      - numeric audit UID (4294967295 = unset)
    SYSCALL.tty       - controlling terminal or "(none)"
    EXECVE.ARGV       - command-line argument array
    CWD.cwd           - current working directory
    PATH              - array of file path records
    PROCTITLE.ARGV    - process title argument array
-->

<group name="laurel,">


  <!-- ===================================================================== -->
  <!-- BASE RULES                                                            -->
  <!-- ===================================================================== -->

  <!-- Base: any event from the LAUREL audit log.  Level 0 = no alert;       -->
  <!-- serves only as a parent for all child rules below.                    -->
  <rule id="100100" level="0">
    <location>/var/log/laurel/audit.log</location>
    <description>LAUREL: base audit event.</description>
    <group>laurel,</group>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 3: SELF-AUDITING: PROTECT THE AUDIT SUBSYSTEM                 -->
  <!-- Keys: auditlog, auditconfig, audittools                              -->
  <!-- ===================================================================== -->

  <rule id="100110" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^auditlog$</field>
    <description>LAUREL: audit log directory accessed or modified -- possible evidence tampering.</description>
    <group>laurel,audit_tampering,</group>
    <mitre>
      <id>T1070</id>
      <id>T1070.002</id>
    </mitre>
  </rule>

  <!-- Whitelist: wazuh-logcollector reading audit.log is normal agent operation -->
  <rule id="100114" level="0">
    <if_sid>100110</if_sid>
    <field name="SYSCALL.exe">/var/ossec/bin/wazuh-logcollector$</field>
    <description>LAUREL: audit log access by wazuh-logcollector (whitelisted).</description>
    <group>laurel,audit_tampering,</group>
  </rule>

  <rule id="100111" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^auditconfig$</field>
    <description>LAUREL: audit configuration modified -- detection coverage may be altered.</description>
    <group>laurel,audit_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="100112" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^audittools$</field>
    <description>LAUREL: audit management tool executed (auditctl/ausearch/aureport).</description>
    <group>laurel,audit_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <!-- Elevated: auditctl executed specifically (can flush all rules) -->
  <rule id="100113" level="13">
    <if_sid>100112</if_sid>
    <field name="SYSCALL.exe">auditctl$</field>
    <description>LAUREL: auditctl executed -- rules may be flushed or modified at runtime.</description>
    <group>laurel,audit_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 4: COMMAND EXECUTION                                          -->
  <!-- Keys: exec, exec_root_unattributed, priv_esc                         -->
  <!-- ===================================================================== -->

  <!-- Broad execve by interactive users; extremely high volume.             -->
  <!-- Level 0: captured by LAUREL for forensics; no Wazuh alert.           -->
  <rule id="100120" level="0">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^exec$</field>
    <description>LAUREL: command executed by interactive user.</description>
    <group>laurel,execution,</group>
  </rule>

  <!-- Interactive command logging: alert when command is executed from a    -->
  <!-- real terminal session (TTY attached). Filters out background          -->
  <!-- processes, daemons, and cron jobs that have tty="(none)".            -->
  <rule id="100122" level="3">
    <if_sid>100120</if_sid>
    <field name="SYSCALL.tty" negate="yes">^\(none\)$</field>
    <description>LAUREL: interactive command executed on terminal.</description>
    <group>laurel,execution,interactive,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <!-- Unattributed root execution (cron, init scripts); high volume.       -->
  <rule id="100121" level="0">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^exec_root_unattributed$</field>
    <description>LAUREL: unattributed root command execution (auid unset).</description>
    <group>laurel,execution,</group>
  </rule>

  <!-- Privilege escalation binary executed -->
  <!-- Note: specific audit keys like "priv_esc" are shadowed by the broad     -->
  <!-- execve rule (key="exec") when auid>=1000. Match on SYSCALL.exe instead. -->
  <rule id="100130" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/bin/su$|/bin/sudo$|/bin/pkexec$|/bin/dbus-send$</field>
    <description>LAUREL: privilege escalation binary executed (su/sudo/pkexec/dbus-send).</description>
    <group>laurel,privilege_escalation,</group>
    <mitre>
      <id>T1548</id>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- pkexec specifically: CVE-2021-4034 (PwnKit) vector -->
  <rule id="100131" level="12">
    <if_sid>100130</if_sid>
    <field name="SYSCALL.exe">pkexec$</field>
    <description>LAUREL: pkexec executed -- potential PwnKit exploitation (CVE-2021-4034).</description>
    <group>laurel,privilege_escalation,exploit,</group>
    <mitre>
      <id>T1068</id>
      <id>T1548</id>
    </mitre>
  </rule>

  <!-- dbus-send: CVE-2021-3560 (polkit bypass) vector -->
  <rule id="100132" level="10">
    <if_sid>100130</if_sid>
    <field name="SYSCALL.exe">dbus-send$</field>
    <description>LAUREL: dbus-send executed -- potential polkit bypass (CVE-2021-3560).</description>
    <group>laurel,privilege_escalation,exploit,</group>
    <mitre>
      <id>T1068</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 5: SERVICE MANAGEMENT                                         -->
  <!-- Keys: service_exec, service_change, cron, modules                     -->
  <!-- ===================================================================== -->

  <rule id="100140" level="5">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/bin/systemctl$</field>
    <description>LAUREL: systemctl executed -- service state change.</description>
    <group>laurel,service_management,</group>
    <mitre>
      <id>T1569.002</id>
    </mitre>
  </rule>

  <rule id="100141" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^service_change$</field>
    <description>LAUREL: systemd unit or init script modified -- possible persistence.</description>
    <group>laurel,persistence,</group>
    <mitre>
      <id>T1543.002</id>
    </mitre>
  </rule>

  <rule id="100142" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^cron$</field>
    <description>LAUREL: cron configuration modified -- possible persistence via scheduled task.</description>
    <group>laurel,persistence,</group>
    <mitre>
      <id>T1053.003</id>
    </mitre>
  </rule>

  <rule id="100143" level="13">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^modules$</field>
    <description>LAUREL: kernel module loaded, unloaded, or config modified -- possible rootkit.</description>
    <group>laurel,rootkit,</group>
    <mitre>
      <id>T1547.006</id>
      <id>T1014</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 6: CRITICAL FILE ACCESS                                       -->
  <!-- Keys: identity, pam, sshd, rootkey, sudoers, ssl_keys,               -->
  <!--       network_config, kernel_config, boot_config, lib_preload,        -->
  <!--       login, syslog, access_denied                                    -->
  <!-- ===================================================================== -->

  <!-- Identity and authentication databases -->

  <rule id="100160" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^identity$</field>
    <description>LAUREL: identity file modified (passwd/shadow/group/gshadow).</description>
    <group>laurel,account_manipulation,</group>
    <mitre>
      <id>T1136</id>
      <id>T1098</id>
    </mitre>
  </rule>

  <!-- /etc/shadow specifically: credential harvesting risk -->
  <rule id="100161" level="13">
    <if_sid>100160</if_sid>
    <field name="SYSCALL.exe" negate="yes">/sbin/useradd$|/sbin/userdel$|/sbin/usermod$|/bin/passwd$|/bin/chage$</field>
    <match>shadow</match>
    <description>LAUREL: /etc/shadow modified by unexpected process -- possible credential manipulation.</description>
    <group>laurel,account_manipulation,credential_access,</group>
    <mitre>
      <id>T1003.008</id>
    </mitre>
  </rule>

  <!-- PAM -->

  <rule id="100162" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^pam$</field>
    <description>LAUREL: PAM configuration modified -- authentication controls may be weakened.</description>
    <group>laurel,authentication,persistence,</group>
    <mitre>
      <id>T1556</id>
    </mitre>
  </rule>

  <!-- SSH -->

  <rule id="100163" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^sshd$</field>
    <description>LAUREL: SSH daemon configuration modified.</description>
    <group>laurel,sshd,persistence,</group>
    <mitre>
      <id>T1098.004</id>
    </mitre>
  </rule>

  <rule id="100164" level="13">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^rootkey$</field>
    <description>LAUREL: root SSH key directory modified -- possible SSH backdoor.</description>
    <group>laurel,sshd,persistence,</group>
    <mitre>
      <id>T1098.004</id>
    </mitre>
  </rule>

  <!-- Sudoers -->

  <rule id="100165" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^sudoers$</field>
    <description>LAUREL: sudoers configuration modified -- arbitrary root access may have been granted.</description>
    <group>laurel,privilege_escalation,persistence,</group>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- SSL/TLS keys -->

  <rule id="100166" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^ssl_keys$</field>
    <description>LAUREL: SSL/TLS private key or certificate accessed.</description>
    <group>laurel,credential_access,</group>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>

  <!-- Whitelist: fwupd reading its own metadata CA certificate is normal operation -->
  <rule id="100176" level="0">
    <if_sid>100166</if_sid>
    <field name="SYSCALL.exe">/usr/libexec/fwupd/fwupd$</field>
    <match>/etc/pki/fwupd-metadata/</match>
    <description>LAUREL: SSL/TLS certificate access by fwupd (whitelisted).</description>
    <group>laurel,credential_access,</group>
  </rule>

  <!-- Network configuration -->

  <rule id="100167" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^network_config$</field>
    <description>LAUREL: network configuration changed (hosts/hostname/resolv.conf/routing).</description>
    <group>laurel,network_change,</group>
    <mitre>
      <id>T1565.001</id>
    </mitre>
  </rule>

  <!-- sethostname/setdomainname syscall specifically -->
  <rule id="100168" level="10">
    <if_sid>100167</if_sid>
    <field name="SYSCALL.SYSCALL">^sethostname$|^setdomainname$</field>
    <description>LAUREL: system hostname or domain name changed via syscall.</description>
    <group>laurel,network_change,</group>
    <mitre>
      <id>T1565.001</id>
    </mitre>
  </rule>

  <!-- Kernel / boot configuration -->

  <rule id="100169" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^kernel_config$</field>
    <description>LAUREL: kernel sysctl configuration modified -- hardening may be weakened.</description>
    <group>laurel,defense_evasion,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="100170" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^boot_config$</field>
    <description>LAUREL: boot loader configuration modified -- possible boot-level persistence.</description>
    <group>laurel,persistence,rootkit,</group>
    <mitre>
      <id>T1542</id>
    </mitre>
  </rule>

  <!-- Library preload (rootkit persistence) -->

  <rule id="100171" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^lib_preload$</field>
    <description>LAUREL: ld.so.preload or ld.so.conf modified -- HIGH RISK rootkit/library injection vector.</description>
    <group>laurel,rootkit,persistence,</group>
    <mitre>
      <id>T1574.006</id>
      <id>T1014</id>
    </mitre>
  </rule>

  <!-- Login / session tracking -->

  <rule id="100172" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^login$</field>
    <description>LAUREL: login tracking file modified (utmp/wtmp/btmp/lastlog/faillog).</description>
    <group>laurel,anti_forensics,</group>
    <mitre>
      <id>T1070</id>
    </mitre>
  </rule>

  <!-- System logs -->

  <rule id="100173" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^syslog$</field>
    <description>LAUREL: system log file tampered (syslog/kern.log/auth.log).</description>
    <group>laurel,anti_forensics,</group>
    <mitre>
      <id>T1070.002</id>
    </mitre>
  </rule>

  <!-- Failed access on sensitive directories -->

  <rule id="100174" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^access_denied$</field>
    <description>LAUREL: failed file access on sensitive directory -- possible reconnaissance.</description>
    <group>laurel,reconnaissance,</group>
    <mitre>
      <id>T1083</id>
    </mitre>
  </rule>

  <!-- Frequency: many denied accesses in a short window = active probing -->
  <rule id="100175" level="12" frequency="8" timeframe="120">
    <if_matched_sid>100174</if_matched_sid>
    <description>LAUREL: repeated failed file access on sensitive directories -- active reconnaissance in progress.</description>
    <group>laurel,reconnaissance,</group>
    <mitre>
      <id>T1083</id>
      <id>T1046</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 7: USER AND GROUP MANAGEMENT                                  -->
  <!-- Keys: user_mgmt, group_mgmt                                          -->
  <!-- ===================================================================== -->

  <rule id="100200" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/sbin/useradd$|/sbin/userdel$|/sbin/usermod$|/sbin/adduser$|/bin/passwd$|/bin/chage$|/bin/chfn$</field>
    <description>LAUREL: user management tool executed (useradd/userdel/usermod/passwd/chage/chfn).</description>
    <group>laurel,account_manipulation,</group>
    <mitre>
      <id>T1136.001</id>
      <id>T1098</id>
    </mitre>
  </rule>

  <rule id="100201" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/sbin/groupadd$|/sbin/groupmod$|/sbin/groupdel$|/sbin/addgroup$</field>
    <description>LAUREL: group management tool executed (groupadd/groupmod/groupdel).</description>
    <group>laurel,account_manipulation,</group>
    <mitre>
      <id>T1136.001</id>
      <id>T1098</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 8: DAC MODIFICATIONS                                          -->
  <!-- Key: perm_mod                                                         -->
  <!-- ===================================================================== -->

  <rule id="100210" level="5">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^perm_mod$</field>
    <description>LAUREL: file permissions or ownership changed (chmod/chown/setxattr).</description>
    <group>laurel,file_integrity,</group>
    <mitre>
      <id>T1222.002</id>
    </mitre>
  </rule>

  <!-- Frequency: many permission changes in a burst = post exploit activity -->
  <rule id="100211" level="10" frequency="10" timeframe="60">
    <if_matched_sid>100210</if_matched_sid>
    <description>LAUREL: burst of file permission changes -- possible post-exploitation activity.</description>
    <group>laurel,file_integrity,</group>
    <mitre>
      <id>T1222.002</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 9: TIME MANIPULATION                                          -->
  <!-- Key: time_change                                                      -->
  <!-- ===================================================================== -->

  <rule id="100220" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^time_change$</field>
    <description>LAUREL: system time or timezone changed -- log correlation may be disrupted.</description>
    <group>laurel,defense_evasion,</group>
    <mitre>
      <id>T1070.006</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 10: NETWORK AND FIREWALL                                      -->
  <!-- Keys: firewall, network_tools, remote_shell                           -->
  <!-- ===================================================================== -->

  <rule id="100230" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/sbin/iptables$|/sbin/ip6tables$|/sbin/nft$|/sbin/xtables-nft-multi$|/sbin/arptables$|/sbin/ebtables$</field>
    <description>LAUREL: firewall management tool executed (iptables/nft/ebtables).</description>
    <group>laurel,firewall,</group>
    <mitre>
      <id>T1562.004</id>
    </mitre>
  </rule>

  <!-- ufw is a Python script: SYSCALL.exe is the interpreter, so match comm -->
  <rule id="100235" level="10">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.comm">^ufw$</field>
    <description>LAUREL: firewall management tool executed (ufw).</description>
    <group>laurel,firewall,</group>
    <mitre>
      <id>T1562.004</id>
    </mitre>
  </rule>

  <rule id="100231" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/sbin/tcpdump$|/sbin/traceroute$|/bin/netstat$|/bin/ss$|/bin/nc$|/bin/nc\.openbsd$</field>
    <description>LAUREL: network reconnaissance or packet capture tool executed.</description>
    <group>laurel,reconnaissance,</group>
    <mitre>
      <id>T1040</id>
      <id>T1049</id>
    </mitre>
  </rule>

  <!-- tcpdump specifically: packet capture on production warrants investigation -->
  <rule id="100232" level="12">
    <if_sid>100231</if_sid>
    <field name="SYSCALL.exe">tcpdump$</field>
    <description>LAUREL: tcpdump executed -- active packet capture on production host.</description>
    <group>laurel,reconnaissance,</group>
    <mitre>
      <id>T1040</id>
    </mitre>
  </rule>

  <!-- netcat specifically: commonly used for reverse shells -->
  <rule id="100233" level="12">
    <if_sid>100231</if_sid>
    <field name="SYSCALL.exe">nc$|nc\.openbsd$|ncat$</field>
    <description>LAUREL: netcat executed -- commonly used for reverse shells and port scanning.</description>
    <group>laurel,execution,lateral_movement,</group>
    <mitre>
      <id>T1059</id>
      <id>T1095</id>
    </mitre>
  </rule>

  <!-- Reverse shell: successful connect() from bash/sh -->
  <rule id="100234" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^remote_shell$</field>
    <description>LAUREL: interactive shell made outbound network connection -- PROBABLE REVERSE SHELL.</description>
    <group>laurel,command_and_control,</group>
    <mitre>
      <id>T1059.004</id>
      <id>T1071</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 11: DATA EXFILTRATION INDICATORS                              -->
  <!-- Keys: exfil_tools, compression                                        -->
  <!-- ===================================================================== -->

  <rule id="100250" level="6">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/bin/wget$|/bin/curl$|/bin/scp$|/bin/sftp$|/bin/ftp$|/bin/rsync$|/bin/base64$</field>
    <description>LAUREL: data transfer tool executed (curl/wget/scp/sftp/rsync/base64).</description>
    <group>laurel,exfiltration,</group>
    <mitre>
      <id>T1041</id>
      <id>T1567</id>
    </mitre>
  </rule>

  <!-- base64 specifically: frequently used to encode payloads -->
  <rule id="100251" level="8">
    <if_sid>100250</if_sid>
    <field name="SYSCALL.exe">base64$</field>
    <description>LAUREL: base64 executed -- may encode payloads or data for exfiltration.</description>
    <group>laurel,exfiltration,defense_evasion,</group>
    <mitre>
      <id>T1132.001</id>
