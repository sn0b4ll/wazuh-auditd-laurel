    <group>laurel,exfiltration,</group>
    <mitre>
      <id>T1560.001</id>
    </mitre>
  </rule>

  <!-- Frequency: transfer tool shortly after compression = exfil staging -->
  <rule id="100253" level="12" frequency="2" timeframe="300">
    <if_matched_sid>100250</if_matched_sid>
    <description>LAUREL: multiple data transfer tools executed in short window -- possible active exfiltration.</description>
    <group>laurel,exfiltration,</group>
    <mitre>
      <id>T1041</id>
