  <!-- ===================================================================== -->
  <!-- SECTION 12: SUSPICIOUS / RECON ACTIVITY                               -->
  <!-- Keys: recon, interpreter                                              -->
  <!-- ===================================================================== -->

  <rule id="100260" level="5">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/bin/whoami$|/bin/id$|/bin/hostname$|/bin/uname$|/bin/uptime$|/bin/w$|/bin/last$</field>
    <description>LAUREL: reconnaissance tool executed (whoami/id/hostname/uname/w/last).</description>
    <group>laurel,reconnaissance,</group>
    <mitre>
      <id>T1082</id>
      <id>T1033</id>
    </mitre>
  </rule>

  <!-- Frequency: burst of recon tools = enumeration phase post compromise -->
  <rule id="100261" level="10" frequency="4" timeframe="120">
    <if_matched_sid>100260</if_matched_sid>
    <description>LAUREL: rapid succession of reconnaissance tools -- probable post-compromise enumeration.</description>
    <group>laurel,reconnaissance,</group>
    <mitre>
      <id>T1082</id>
      <id>T1033</id>
      <id>T1083</id>
    </mitre>
  </rule>

  <rule id="100262" level="4">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.exe">/bin/python3|/bin/perl$</field>
    <description>LAUREL: script interpreter executed (python3/perl).</description>
    <group>laurel,execution,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 13: POWER, SPECIAL FILES, AND SYSTEM STATE                    -->
  <!-- Keys: power, kexec, mknod, mount                                     -->
  <!-- ===================================================================== -->

  <rule id="100270" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^power$</field>
    <description>LAUREL: system power command executed (shutdown/reboot/halt/poweroff).</description>
    <group>laurel,system_state,</group>
    <mitre>
      <id>T1529</id>
    </mitre>
  </rule>

  <rule id="100271" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^kexec$</field>
    <description>LAUREL: kexec_load syscall invoked -- kernel replacement without reboot, possible rootkit.</description>
    <group>laurel,rootkit,</group>
    <mitre>
      <id>T1014</id>
      <id>T1601</id>
    </mitre>
  </rule>

  <rule id="100272" level="8">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^mknod$</field>
    <description>LAUREL: device node created via mknod -- may bypass filesystem permissions.</description>
    <group>laurel,privilege_escalation,</group>
    <mitre>
      <id>T1200</id>
    </mitre>
  </rule>

  <rule id="100273" level="6">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^mount$</field>
    <description>LAUREL: filesystem mounted or unmounted.</description>
    <group>laurel,system_state,</group>
    <mitre>
      <id>T1052</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- SECTION 14: WAZUH AGENT INTEGRITY                                     -->
  <!-- Keys: wazuh_config, wazuh_keys, wazuh_bin, wazuh_exec,               -->
  <!--       wazuh_lib, wazuh_logs, wazuh_ar, wazuh_ruleset                 -->
  <!--                                                                       -->
  <!-- All Wazuh tampering events are HIGH or CRITICAL severity.  An         -->
  <!-- attacker who can modify the security agent operates undetected.       -->
  <!-- ===================================================================== -->

  <rule id="100300" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_config$</field>
    <description>LAUREL: Wazuh agent configuration modified -- detection scope may be reduced.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="100301" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_keys$</field>
    <description>LAUREL: Wazuh agent authentication keys accessed or modified -- possible agent impersonation.</description>
    <group>laurel,wazuh_tampering,credential_access,</group>
    <mitre>
      <id>T1562.001</id>
      <id>T1552</id>
    </mitre>
  </rule>

  <rule id="100302" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_bin$</field>
    <description>LAUREL: Wazuh agent binary or upgrade staging area modified -- possible trojan replacement.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
      <id>T1554</id>
    </mitre>
  </rule>

  <rule id="100303" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.comm">^wazuh-control$|^agent-auth$|^manage_agents$</field>
    <description>LAUREL: Wazuh control script or enrollment tool executed.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <!-- Elevated: wazuh-control with stop argument -->
  <rule id="100304" level="14">
    <if_sid>100303</if_sid>
    <match>stop</match>
    <description>LAUREL: Wazuh agent stop command detected -- agent may be silenced.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="100305" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_lib$</field>
    <description>LAUREL: Wazuh shared library modified -- possible library injection to filter events.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
      <id>T1574.006</id>
    </mitre>
  </rule>

  <rule id="100306" level="12">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_logs$</field>
    <description>LAUREL: Wazuh agent logs modified or deleted -- possible evidence destruction.</description>
    <group>laurel,wazuh_tampering,anti_forensics,</group>
    <mitre>
      <id>T1070.002</id>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <!-- Whitelist: Wazuh agent binaries writing to their own logs is normal operation -->
  <rule id="100309" level="0">
    <if_sid>100306</if_sid>
    <field name="SYSCALL.exe">^/var/ossec/bin/</field>
    <description>LAUREL: Wazuh agent log access by Wazuh process (whitelisted).</description>
    <group>laurel,wazuh_tampering,</group>
  </rule>

  <rule id="100307" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_ar$</field>
    <description>LAUREL: Wazuh active-response scripts modified -- automated defenses may be neutralized.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="100308" level="14">
    <if_sid>100100</if_sid>
    <field name="SYSCALL.key">^wazuh_ruleset$</field>
    <description>LAUREL: Wazuh ruleset or decoders modified -- detection rules may be suppressed.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>


  <!-- ===================================================================== -->
  <!-- COMPOSITE / BEHAVIORAL RULES                                          -->
  <!-- Higher-confidence detections combining multiple signals.              -->
  <!-- ===================================================================== -->

  <!-- Multiple Wazuh tampering events in short window = active attack on agent -->
  <rule id="100350" level="15" frequency="3" timeframe="300">
    <if_matched_group>wazuh_tampering</if_matched_group>
    <description>LAUREL: CRITICAL -- multiple Wazuh agent tampering events in 5 minutes -- active attack on security agent.</description>
    <group>laurel,wazuh_tampering,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <!-- Multiple audit-tampering events = attacker covering tracks -->
  <rule id="100351" level="14" frequency="3" timeframe="300">
    <if_matched_group>audit_tampering</if_matched_group>
    <description>LAUREL: multiple audit subsystem tampering events -- attacker may be covering tracks.</description>
    <group>laurel,audit_tampering,anti_forensics,</group>
    <mitre>
      <id>T1070</id>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <!-- Multiple persistence mechanisms touched in short window -->
  <rule id="100352" level="13" frequency="3" timeframe="600">
    <if_matched_group>persistence</if_matched_group>
    <description>LAUREL: multiple persistence mechanisms modified in 10 minutes -- possible multi-vector persistence installation.</description>
    <group>laurel,persistence,</group>
    <mitre>
      <id>T1543.002</id>
      <id>T1053.003</id>
    </mitre>
  </rule>

  <!-- Recon followed by privilege escalation = classic post-exploit pattern -->
  <rule id="100353" level="12" frequency="2" timeframe="300">
    <if_matched_group>privilege_escalation</if_matched_group>
    <description>LAUREL: multiple privilege escalation attempts in 5 minutes.</description>
    <group>laurel,privilege_escalation,</group>
    <mitre>
      <id>T1548</id>
    </mitre>
  </rule>


</group> <!-- /laurel -->
